<UserControl x:Class="ClientServerTcpGame.Views.RatingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Rating"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 10"/>

        <DataGrid x:Name="Grid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  MinHeight="250">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding name}" Width="*"/>
                <DataGridTextColumn Header="Games" Binding="{Binding games}" Width="70"/>
                <DataGridTextColumn Header="Wins" Binding="{Binding wins}" Width="60"/>
                <DataGridTextColumn Header="TotalScore" Binding="{Binding totalScore}" Width="90"/>
                <DataGridTextColumn Header="AvgScore" Binding="{Binding avgScore, StringFormat={}{0:0.##}}" Width="85"/>

                <DataGridTextColumn Header="Own" Binding="{Binding ownClicks}" Width="60"/>
                <DataGridTextColumn Header="Enemy" Binding="{Binding enemyClicks}" Width="70"/>
                <DataGridTextColumn Header="Neutral" Binding="{Binding neutralClicks}" Width="80"/>
                <DataGridTextColumn Header="Total" Binding="{Binding totalClicks}" Width="70"/>

                <DataGridTextColumn Header="AvgTotal" Binding="{Binding avgTotalClicks, StringFormat={}{0:0.##}}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
