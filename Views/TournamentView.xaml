<UserControl x:Class="ClientServerTcpGame.Views.TournamentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="10">
        <TextBlock Text="Tournament Results"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 10"/>

        <DataGrid x:Name="Grid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  MinHeight="220">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Place" Binding="{Binding place}" Width="60"/>
                <DataGridTextColumn Header="Name" Binding="{Binding name}" Width="*"/>
                <DataGridTextColumn Header="Total" Binding="{Binding totalScore}" Width="80"/>

                <DataGridTextColumn Header="R1" Binding="{Binding r1}" Width="60"/>
                <DataGridTextColumn Header="R2" Binding="{Binding r2}" Width="60"/>
                <DataGridTextColumn Header="R3" Binding="{Binding r3}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Back"
                Width="120"
                HorizontalAlignment="Center"
                Margin="0 10 0 0"
                Click="Back_Click"/>
    </StackPanel>
</UserControl>
