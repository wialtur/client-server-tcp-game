<UserControl x:Class="ClientServerTcpGame.Views.ResultView"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="380"
                Margin="10">

        <TextBlock Text="Game Over"
                   FontSize="22"
                   FontWeight="SemiBold"
                   TextAlignment="Center"
                   Margin="0 0 0 12"/>

        <!-- General -->
        <TextBlock x:Name="ReasonText" Margin="0 2"/>
        <TextBlock x:Name="DurationText" Margin="0 2"/>

        <!-- Colors as squares -->
        <StackPanel Orientation="Horizontal" Margin="0 6" VerticalAlignment="Center">
            <TextBlock Text="Colors:" VerticalAlignment="Center" Margin="0,0,8,0"/>

            <TextBlock Text="P1" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Rectangle x:Name="P1ColorRect" Width="18" Height="18" Stroke="Black" Margin="0,0,12,0"/>

            <TextBlock Text="P2" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Rectangle x:Name="P2ColorRect" Width="18" Height="18" Stroke="Black"/>
        </StackPanel>

        <TextBlock x:Name="FinalText" FontWeight="Bold" Margin="0 6"/>

        <Separator Margin="0 10"/>

        <!-- Player 1 -->
        <TextBlock Text="Player 1 stats:" FontWeight="SemiBold"/>
        <TextBlock x:Name="P1StatsText" Margin="0 2"/>

        <Separator Margin="0 8"/>

        <!-- Player 2 -->
        <TextBlock Text="Player 2 stats:" FontWeight="SemiBold"/>
        <TextBlock x:Name="P2StatsText" Margin="0 2"/>

        <Separator Margin="0 12"/>

        <Button Content="Show Rating"
                Click="Rating_Click"
                Margin="0 4"/>

        <Button Content="Exit"
                Click="Exit_Click"
                Margin="0 4"/>
    </StackPanel>
</UserControl>