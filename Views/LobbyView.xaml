<UserControl x:Class="ClientServerTcpGame.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
        <TextBlock Text="Lobby" FontSize="20" Margin="0 0 0 10"/>

        <TextBlock Text="Pick color:" Margin="0 0 0 6"/>

        <DockPanel Margin="0 0 0 8">
            <TextBlock Text="Selected:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Rectangle x:Name="ColorPreview" Width="22" Height="22" Stroke="Black"/>
        </DockPanel>

        <UniformGrid x:Name="PaletteGrid" Rows="2" Columns="4" Margin="0 0 0 10"/>

        <CheckBox x:Name="ReadyBox" Content="Ready"
                  Checked="Ready_Checked"
                  Unchecked="Ready_Unchecked"/>
    </StackPanel>
</UserControl>