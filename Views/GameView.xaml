<UserControl x:Class="ClientServerTcpGame.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- top bar -->
        <DockPanel Grid.Row="0" Background="#222" LastChildFill="False" Margin="10,6">
            <TextBlock x:Name="TimerText" Foreground="White" FontSize="16" FontWeight="SemiBold"
                       DockPanel.Dock="Left" Text="Time: 30.0"/>
            <TextBlock x:Name="RoundText" Foreground="White" Margin="10,0,0,0"
                       VerticalAlignment="Center" Text="" Visibility="Collapsed"/>
            <TextBlock x:Name="ScoreText" Foreground="White" FontSize="16" Margin="20,0,0,0"
                       DockPanel.Dock="Left" Text="Score: 0 : 0"/>
        </DockPanel>

        <!-- field -->
        <Canvas x:Name="Field" Grid.Row="1" Background="Black" MouseLeftButtonDown="Field_Click"/>
    </Grid>
</UserControl>
