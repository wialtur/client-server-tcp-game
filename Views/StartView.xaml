<UserControl x:Class="ClientServerTcpGame.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Width="260"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <!-- Player name -->
        <TextBlock Text="Player name"
               Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox"
             Margin="0,0,0,10"/>

        <!-- IP -->
        <TextBlock Text="Server IP"
               Margin="0,0,0,4"/>
        <TextBox x:Name="IpBox"
             Text="127.0.0.1"
             Margin="0,0,0,10"/>

        <!-- Port -->
        <TextBlock Text="Port"
               Margin="0,0,0,4"/>
        <TextBox x:Name="PortBox"
             Text="9000"
             Margin="0,0,0,10"/>

        <!-- Level -->
        <TextBlock Text="Game level"
               Margin="0,0,0,4"/>
        <ComboBox x:Name="LevelBox"
              SelectedIndex="0"
              Margin="0,0,0,10">
            <ComboBoxItem Content="Level 1"/>
            <ComboBoxItem Content="Level 2"/>
            <ComboBoxItem Content="Level 3"/>
        </ComboBox>

        <!-- Tournament -->
        <CheckBox x:Name="TournamentBox"
              Content="Tournament (3 rounds)"
              Margin="0,0,0,14"/>

        <!-- Buttons -->
        <Button Content="Host"
            Click="Host_Click"
            Margin="0,0,0,6"/>

        <Button Content="Join"
            Click="Join_Click"/>
    </StackPanel>
</UserControl>
